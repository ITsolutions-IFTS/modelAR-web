# Sketchfab API key — https://sketchfab.com/settings/password
# Sin prefijo VITE_: solo disponible en vite.config.ts (Node), nunca en el bundle del cliente
SKETCHFAB_API_KEY=

# URL base de la API (sin slash final)
# Dev local: http://localhost:5000
# Prod: https://api.modelar.com
VITE_API_BASE_URL=

# Origin público de la web para los QR del visor AR.
# Prod: la URL real desplegada (ej. https://model-ar-web.vercel.app).
# Vacío en dev: el QR usa window.location.origin (necesita túnel para el celu).
VITE_PUBLIC_WEB_URL=
